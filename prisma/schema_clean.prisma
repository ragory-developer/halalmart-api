generator client {
}
datasource db {
}
model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  password     String?
  name         String
  phone        String?       @unique
  isGuest      Boolean       @default(false)
  role         Role          @default(USER)
  address      String?
  city         String?
  area         String?
  gender       String?
  dateOfBirth  DateTime?
  rewardPoints Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cart         Cart?
  orders       Order[]
  wishlist     Wishlist[]
  addresses    UserAddress[]
  walletTransactions WalletTransaction[]
  @@index([email])
  @@index([phone])
}
model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  city      String
  area      String
  state     String?
  stateId   String?
  cityId    String?
  areaId    String?
  isDefault      Boolean  @default(false)
  recipientName  String?
  recipientPhone String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([userId])
  @@index([stateId])
  @@index([cityId])
  @@index([areaId])
}
model OTPVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  blockedUntil DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([phone])
}
model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  @@index([slug])
}
model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  image     String?
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  @@index([slug])
}
model Product {
  id                  String           @id @default(cuid())
  name                String
  slug                String           @unique
  price               Float
  stock               Int              @default(0)
  image               String?
  weight              String?
  featured            Boolean          @default(false)
  brandId             String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  specialPrice        Float?
  specialPriceEnd     DateTime?
  specialPriceStart   DateTime?
  productType         ProductType      @default(SIMPLE)
  externalId          String?          @unique
  averageRating       Float            @default(0)
  ratingCount         Int              @default(0)
  comparePrice        Float?
  cartItems           CartItem[]
  orderItems          OrderItem[]
  variants            ProductVariant[]
  reviews             Review[]
  wishlist            Wishlist[]
  @@index([slug])
  @@index([brandId])
  @@index([name])
}
model Review {
  id            String   @id @default(cuid())
  productId     String
  externalId    String?  @unique
  rating        Int      @default(5)
  reviewer      String
  reviewerEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([productId])
}
model ProductVariant {
  id                String             @id @default(cuid())
  productId         String
  sku               String?
  price             Float
  stock             Int                @default(0)
  image             String?
  isDefault         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  specialPrice      Float?
  enabled           Boolean            @default(true)
  specialPriceEnd   DateTime?
  specialPriceStart DateTime?
  cartItems         CartItem[]
  orderItems        OrderItem[]
  attributes        VariantAttribute[]
  @@index([productId])
}
model VariantAttribute {
  id        String         @id @default(cuid())
  variantId String
  name      String
  value     String
  @@index([variantId])
}
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}
model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String?
  variantId String?
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}
model Order {
  id              String        @id @default(cuid())
  userId          String
  customerName    String?
  customerPhone   String?
  status          OrderStatus   @default(PENDING)
  total           Float
  subtotal        Float
  deliveryFee     Float         @default(0)
  discount        Float         @default(0)
  rewardPoints    Int           @default(0)
  deliveryAddress String
  deliveryCity    String?
  deliveryArea    String?
  deliveryState   String?
  deliveryStateId String?
  deliveryCityId  String?
  deliveryAreaId  String?
  deliverySlot    String?
  paymentMethod   PaymentMethod @default(COD)
  couponCode      String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           OrderItem[]
  @@index([userId])
  @@index([status])
  @@index([deliveryStateId])
  @@index([deliveryCityId])
  @@index([deliveryAreaId])
}
model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String?
  variantId String?
  quantity  Int
  price     Float
  @@index([orderId])
}
model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
}
model Coupon {
  id        String       @id @default(cuid())
  code      String       @unique
  discount  Float
  type      DiscountType @default(PERCENT)
  minOrder  Float        @default(0)
  maxUses   Int          @default(100)
  usedCount Int          @default(0)
  active    Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  @@index([code])
}
model Media {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  fileSize     Int
  altText      String?
  title        String?
  caption      String?
  width        Int?
  height       Int?
  urlThumbnail String
  urlMedium    String
  urlFull      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  @@index([slug])
}
model Attribute {
  id           String           @id @default(cuid())
  name         String           @unique
  slug         String           @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  showOnFilter Boolean          @default(true)
  values       AttributeValue[]
  @@index([slug])
}
model AttributeValue {
  id           String    @id @default(cuid())
  value        String
  attributeId  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  showOnFilter Boolean   @default(true)
  @@index([attributeId])
}
model Variation {
  id        String           @id @default(cuid())
  name      String           @unique
  slug      String           @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  values    VariationValue[]
  @@index([slug])
}
model VariationValue {
  id          String    @id @default(cuid())
  value       String
  variationId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([variationId])
}
model WordPressSetting {
  id             String   @id @default(cuid())
  siteUrl        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
model ImportLog {
  id            String    @id @default(cuid())
  totalProducts Int       @default(0)
  imported      Int       @default(0)
  failed        Int       @default(0)
  lastPage      Int       @default(1)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
model ImportTask {
  id         String    @id @default(cuid())
  name       String
  pageNumber Int
  perPage    Int       @default(20)
  totalItems Int       @default(0)
  imported   Int       @default(0)
  failed     Int       @default(0)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
}
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum ProductType {
  SIMPLE
  VARIABLE
}
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
enum PaymentMethod {
  COD
  CARD
  BKASH
  NAGAD
}
enum DiscountType {
  PERCENT
  FIXED
}
model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([slug])
}
model BuilderPage {
  id                 String               @id @default(cuid())
  key                String               @unique
  slug               String               @unique
  title              String
  draftVersionId     String?
  publishedVersionId String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  versions           BuilderPageVersion[]
  @@index([key])
  @@index([slug])
}
model BuilderPageVersion {
  id          String      @id @default(cuid())
  pageId      String
  version     Int
  document    Json
  createdById String?
  publishedAt DateTime?
  activeFrom  DateTime?
  activeTo    DateTime?
  createdAt   DateTime    @default(now())
}
model WalletTransaction {
  id        String          @id @default(cuid())
  userId    String?
  amount    Float
  type      TransactionType @default(TOPUP)
  note      String?
  createdAt DateTime        @default(now())
  @@index([userId])
}
enum TransactionType {
  TOPUP
  DEDUCTION
  REFUND
}
model State {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]
  addresses UserAddress[]
  orders    Order[]
}
model City {
  id              String   @id @default(cuid())
  name            String
  stateId         String
  deliveryCharge  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  areas     Area[]
  addresses UserAddress[]
  orders    Order[]
  @@index([stateId])
}
model Area {
  id              String   @id @default(cuid())
  name            String
  cityId          String
  deliveryCharge  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  addresses UserAddress[]
  orders    Order[]
  @@index([cityId])
}
model BuilderTemplatePack {
  id          String            @id @default(cuid())
  name        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  templates   BuilderTemplate[]
}
model BuilderTemplate {
  id          String              @id @default(cuid())
  packId      String?
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  @@index([packId])
  @@index([themeKey])
}
model BuilderComponent {
  id        String                  @id @default(cuid())
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  contents  BuilderComponentContent[]
}
model BuilderComponentContent {
  id          String           @id @default(cuid())
  componentId String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@index([componentId])
}
model NavbarItem {
  id        String       @id @default(cuid())
  parentId  String?
  title     String
  url       String
  icon      String?
  cssClass  String?
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  @@index([parentId])
  @@index([isActive])
}
model FooterSection {
  id        String       @id @default(cuid())
  title     String
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  links     FooterLink[]
  @@index([isActive])
}
model FooterLink {
  id        String        @id @default(cuid())
  sectionId String
  title     String
  url       String
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@index([sectionId])
  @@index([isActive])
}
  id        String   @id @default(cuid())
  name      String
  role      String?
  product   String?
  image     String?
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([isActive])
}
