# Server
PORT=5000
NODE_ENV=production    # Use 'production' on your live server

# Database
# Replace user, password, host, port, and dbname with your actual MySQL credentials
DATABASE_URL="mysql://user:password@localhost:3306/dbname"

# JWT Auth Secrets (Change these in production to random secure strings)
JWT_ACCESS_SECRET=your_jwt_access_secret_for_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_for_production
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (CORS) - Set this to your live frontend domain
FRONTEND_URL=https://yourdomain.com

# API URL (Self-reference for media/imports/webhooks)
# Set this to your live backend domain so images load properly
API_URL=https://api.yourdomain.com

# SMS Gateway
SMS_GATEWAY_URL=https://smsmassdata.massdata.xyz/api/sms/send
SMS_API_KEY=your_api_key_here
SMS_COST_PER_SMS=0.40
SMS_SENDER_ID=your_sender_id_here

# SSL Commerz Gateway
SSL_STORE_ID=your_ssl_store_id
SSL_STORE_PASSWORD=your_ssl_store_password
